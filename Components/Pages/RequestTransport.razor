@page "/request"
@attribute [Authorize]
@inject ITransportRequestService TransportRequestService

<PageTitle>Request Transport</PageTitle>

<h1>Request Transport</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<EditForm Model="inputModel" OnValidSubmit="SubmitAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Destination</label>
        <InputText class="form-control" @bind-Value="inputModel.Destination" />
    </div>

    <div class="mb-3">
        <label class="form-label">Passenger Count</label>
        <InputNumber class="form-control" @bind-Value="inputModel.PassengerCount" />
    </div>

    <button type="submit" class="btn btn-primary">Send Request</button>
</EditForm>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success mt-3">@successMessage</div>
}

@code {
    private TransportRequestInput inputModel = new();
    private string? successMessage;
    private string? errorMessage;

    private async Task SubmitAsync()
    {
        try
        {
            errorMessage = null;
            await TransportRequestService.CreateAsync(inputModel);

            successMessage = "Your request has been sent to SNYC admin.";
            inputModel = new TransportRequestInput();
        }
        catch (Exception ex)
        {
            successMessage = null;
            errorMessage = $"Unable to submit request: {ex.Message}";
        }
    }
}