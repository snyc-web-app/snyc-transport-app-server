@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@inject ITransportRequestService TransportRequestService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Admin Dashboard</PageTitle>

<h1>Admin Dashboard</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (!_canManage)
{
    <div class="alert alert-danger" role="alert">
        You are not authorized to access this page.
    </div>
}
else if (requests.Count == 0)
{
    <p>No transport requests yet.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Destination</th>
                <th>Passengers</th>
                <th>Status</th>
                <th>Compliance</th>
                <th>Admin</th>
                <th>Requested (UTC)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var request in requests)
            {
                <tr>
                    <td>@request.Destination</td>
                    <td>@request.passengerCount</td>
                    <td>@request.status</td>
                    <td>@request.complianceStatus</td>
                    <td>@request.adminStatus</td>
                    <td>@request.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <button class="btn btn-sm btn-success me-2" @onclick='() => UpdateStatusAsync(request.Id, "Approved")'>Approve</button>
                        <button class="btn btn-sm btn-warning me-2" @onclick='() => UpdateStatusAsync(request.Id, "Rejected")'>Reject</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteAsync(request.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<TransportRequests> requests = new();
    private bool _canManage;
    private string? errorMessage;

    @* check if user has admin role *@
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _canManage = authState.User.Identity?.IsAuthenticated == true
            && authState.User.IsInRole("Admin");

        if (!_canManage)
        {
            requests.Clear();
            return;
        }

        try
        {
            await LoadRequestsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to load requests: {ex.Message}";
        }
    }

    private async Task UpdateStatusAsync(Guid id, string status)
    {
        if (!_canManage)
        {
            return;
        }

        try
        {
            errorMessage = null;
            await TransportRequestService.UpdateStatusAsync(id, status);
            await LoadRequestsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to update request: {ex.Message}";
        }
    }

    private async Task DeleteAsync(Guid id)
    {
        if (!_canManage)
        {
            return;
        }

        try
        {
            errorMessage = null;
            await TransportRequestService.DeleteAsync(id);
            await LoadRequestsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to delete request: {ex.Message}";
        }
    }

    private async Task LoadRequestsAsync()
    {
        requests = (await TransportRequestService.GetAllAsync()).ToList();
    }
}
